{
	"name": "@mirasen/license-gate",
	"description": "Strict local license policy gate for npm projects.",
	"version": "1.0.0",
	"license": "MIT",
	"author": {
		"name": "Mirasen"
	},
	"keywords": [
		"mirasen",
		"license",
		"license-gate",
		"license-check",
		"license-checker",
		"license-policy",
		"license-compliance",
		"dependency-licenses",
		"npm",
		"workspaces",
		"monorepo",
		"spdx",
		"ci",
		"typescript"
	],
	"homepage": "https://mirasen.io/license-gate",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/mirasen-io/license-gate.git"
	},
	"bugs": {
		"url": "https://github.com/mirasen-io/license-gate/issues"
	},
	"type": "module",
	"types": "./dist/index.d.ts",
	"bin": {
		"license-gate": "./dist/cli.js"
	},
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js",
			"default": "./dist/index.js"
		}
	},
	"scripts": {
		"build": "rimraf ./dist && tsc --project tsconfig.json && npm run postbuild && npm run prepack",
		"build:release": "rimraf ./dist && tsc --project tsconfig-release.json && npm run postbuild && npm run prepack",
		"postbuild": "node scripts/postbuild.js",
		"prepack": "publint",
		"format": "prettier --write .",
		"lint": "prettier --check . && eslint .",
		"check": "tsc --project tsconfig.json --noEmit",
		"check:test": "tsc --project tsconfig-test.json",
		"test": "npm run check:test && vitest run --run",
		"coverage": "npm run check:test && vitest run --coverage",
		"changeset:version": "changeset version && npm install && git add --all",
		"changeset:publish": "changeset publish"
	},
	"files": [
		"dist",
		"CHANGELOG.md",
		"!dist/**/*.test.*",
		"!dist/**/*.spec.*"
	],
	"dependencies": {
		"@npmcli/arborist": "^9.7.0",
		"spdx-expression-parse": "^4.0.0"
	},
	"devDependencies": {
		"@changesets/cli": "^2.28.1",
		"@eslint/compat": "^2.0.0",
		"@eslint/js": "^10.0.1",
		"@types/node": "^25.0.2",
		"@types/npmcli__arborist": "^6.3.3",
		"@vitest/coverage-v8": "^4.1.8",
		"eslint": "^10.0.2",
		"eslint-config-prettier": "^10.1.2",
		"globals": "^17.4.0",
		"prettier": "^3.5.3",
		"publint": "^0.3.11",
		"rimraf": "^6.0.1",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.57.2",
		"vitest": "^4.0.3"
	},
	"engines": {
		"node": ">=22.9.0"
	}
}
